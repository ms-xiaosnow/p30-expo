{
  "expo": {
    "name": "p30-expo-client",
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["peripheral", "central"],
          "bluetoothAlwaysPermission": "为了让您在锁屏时也能接收危险极低血糖警报，App 需要您的蓝牙和始终定位权限支持。"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": { "deploymentTarget": "15.1" }
        }
      ],
      "./withDisableCodeSigning.js"
    ],
    "slug": "p30-expo-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.p30.cgm.client",
      "infoPlist": {
        "UIBackgroundModes": ["bluetooth-central", "bluetooth-peripheral"],
        "NSBluetoothAlwaysUsageDescription": "为了让您在锁屏时也能接收危险极低血糖警报，App 需要蓝牙权限。",
        "NSBluetoothPeripheralUsageDescription": "App 需要蓝牙权限以连接血糖传感器。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
